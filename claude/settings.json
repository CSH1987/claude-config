{
  "extraKnownMarketplaces": {
    "harness-marketplace": {
      "source": { "source": "github", "repo": "revfactory/harness" }
    }
  },
  "enabledPlugins": { "harness@harness-marketplace": true },
  "hooks": {
    "SessionStart": [
      { "hooks": [
